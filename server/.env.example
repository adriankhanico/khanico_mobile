PORT=3001

# Odoo connection (server-side only, never exposed to the client)
# Each request is authenticated as the logged-in user's own Odoo account,
# so no shared service-account credentials are needed here.
ODOO_BASE_URL=https://your-instance.odoo.com
ODOO_DB=your-db-name

# Session cookie signing secret (server-side sessions hold each logged-in
# user's Odoo uid + password in memory for the life of their session)
SESSION_SECRET=replace-with-a-long-random-string

# CORS: the PWA's own deployed origin
CLIENT_ORIGIN=http://localhost:5173
